<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Repair SOP 四層分析</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#0f1117;--surface:#1a1d27;--surface2:#222535;--border:#2e3247;--text:#e2e8f0;--muted:#64748b;--green:#6ee7b7;--amber:#f59e0b;--purple:#818cf8;--pink:#f472b6;--blue:#38bdf8;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans TC',sans-serif;padding:24px;min-height:100vh;}
.wrap{max-width:1300px;margin:0 auto;}
header{margin-bottom:22px;}
header h1{font-family:'JetBrains Mono',monospace;font-size:16px;color:var(--green);margin-bottom:4px;}
header p{font-size:12px;color:var(--muted);}

/* Breadcrumb */
.breadcrumb{display:flex;align-items:center;gap:8px;margin-bottom:18px;font-size:12px;color:var(–muted);font-family:‘JetBrains Mono’,monospace;flex-wrap:wrap;}
.breadcrumb .active{color:var(–green);}
.breadcrumb .sep{color:var(–border);}
.back-btn{padding:5px 12px;border-radius:5px;border:1px solid var(–border);background:var(–surface2);color:var(–muted);font-size:11px;cursor:pointer;transition:all .15s;}
.back-btn:hover{color:var(–text);border-color:var(–green);}

/* L1 tabs */
.lv1-tabs{display:flex;gap:8px;margin-bottom:20px;}
.lv1-tab{padding:9px 28px;border-radius:7px;cursor:pointer;font-family:‘JetBrains Mono’,monospace;font-size:13px;font-weight:700;border:2px solid var(–border);background:var(–surface);color:var(–muted);transition:all .18s;}
.lv1-tab[data-p=“PCIe”].active{background:#1a5c3a;border-color:var(–green);color:var(–green);}
.lv1-tab[data-p=“SATA”].active{background:#7a4500;border-color:var(–amber);color:var(–amber);}

/* KPI */
.insight{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
.icard{background:var(–surface);border:1px solid var(–border);border-radius:9px;padding:13px 15px;}
.icard-label{font-size:10px;color:var(–muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;}
.icard-val{font-family:‘JetBrains Mono’,monospace;font-size:24px;font-weight:700;line-height:1;}
.icard-sub{font-size:10px;color:var(–muted);margin-top:3px;}

/* Charts */
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.chart-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px;}
.card{background:var(–surface);border:1px solid var(–border);border-radius:10px;padding:18px;}
.card-title{font-size:11px;font-weight:700;color:var(–muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:6px;}
.card-title::before{content:’’;width:3px;height:12px;border-radius:2px;background:var(–green);display:inline-block;}

/* L2 RT cards */
.rt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;margin-bottom:20px;}
.rt-card{background:var(–surface);border:1px solid var(–border);border-radius:8px;padding:12px 14px;cursor:pointer;transition:all .18s;}
.rt-card:hover{transform:translateY(-2px);border-color:var(–amber);}
.rt-card.active{border-color:var(–amber);background:rgba(245,158,11,.07);}
.rt-name{font-family:‘JetBrains Mono’,monospace;font-size:12px;font-weight:700;margin-bottom:4px;}
.rt-total{font-family:‘JetBrains Mono’,monospace;font-size:22px;font-weight:700;color:var(–text);line-height:1;}
.rt-sub{font-size:10px;color:var(–muted);margin-top:3px;}

/* L3 SOP list */
.sop-panel{background:var(–surface);border:1px solid var(–border);border-radius:10px;padding:20px;margin-bottom:16px;}
.sop-panel-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid var(–border);}
.sop-panel-header h2{font-size:14px;font-family:‘JetBrains Mono’,monospace;color:var(–amber);}
.sop-search{width:100%;background:var(–surface2);border:1px solid var(–border);border-radius:6px;padding:8px 12px;color:var(–text);font-size:12px;margin-bottom:12px;outline:none;}
.sop-search:focus{border-color:var(–green);}
.sop-item{background:var(–surface2);border:1px solid var(–border);border-radius:8px;margin-bottom:8px;overflow:hidden;transition:border-color .15s;}
.sop-item:hover{border-color:var(–purple);}
.sop-item.open{border-color:var(–purple);}
.sop-header{display:flex;align-items:center;gap:10px;padding:10px 14px;cursor:pointer;}
.sop-badge{background:var(–purple);color:#fff;font-family:‘JetBrains Mono’,monospace;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;white-space:nowrap;}
.sop-text{font-size:12px;color:var(–text);flex:1;line-height:1.4;}
.sop-arrow{color:var(–muted);font-size:12px;transition:transform .2s;flex-shrink:0;}
.sop-item.open .sop-arrow{transform:rotate(90deg);}
.sop-codes{display:none;padding:0 14px 12px;}
.sop-item.open .sop-codes{display:block;}
.code-table{width:100%;border-collapse:collapse;font-size:12px;}
.code-table th{text-align:left;padding:6px 8px;background:var(–surface);color:var(–muted);font-size:10px;letter-spacing:1px;text-transform:uppercase;border-bottom:1px solid var(–border);}
.code-table td{padding:6px 8px;border-bottom:1px solid rgba(46,50,61,.4);vertical-align:top;}
.code-table tr:last-child td{border-bottom:none;}
.code-table tr:hover td{background:rgba(255,255,255,.02);}
.code-tag{font-family:‘JetBrains Mono’,monospace;font-size:11px;font-weight:700;color:var(–green);}
.stage-tag{font-size:10px;color:var(–muted);background:var(–surface);padding:2px 6px;border-radius:3px;}
.type-tag{font-size:10px;color:var(–blue);}
.empty-msg{text-align:center;padding:32px;color:var(–muted);font-size:13px;}
.legend-row{display:flex;gap:14px;margin-top:8px;flex-wrap:wrap;}
.legend-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(–muted);}
.legend-dot{width:8px;height:8px;border-radius:50%;}
@media(max-width:800px){.chart-grid,.chart-grid-3{grid-template-columns:1fr;}.insight{grid-template-columns:repeat(2,1fr);}}
</style>

</head>
<body>
<div class="wrap">
  <header>
    <h1>// PRODUCT → REPAIR_TYPE → SOP → ERROR CODE（四層分析 · CTL = ALL）</h1>
    <p>點選 Repair_Type → 展開 SOP 種類 → 點 SOP 查看對應 Error Code</p>
  </header>

  <div class="breadcrumb" id="breadcrumb">
    <span class="active" id="bc-prod">PCIe</span>
  </div>

  <div class="lv1-tabs">
    <div class="lv1-tab active" data-p="PCIe" onclick="selectProduct('PCIe')">PCIe</div>
    <div class="lv1-tab" data-p="SATA" onclick="selectProduct('SATA')">SATA</div>
  </div>

  <div class="insight">
    <div class="icard"><div class="icard-label">總 Error Code 數量</div><div class="icard-val" id="kpi-total" style="color:var(--green)">—</div><div class="icard-sub" id="kpi-total-sub"></div></div>
    <div class="icard"><div class="icard-label">SOP 種類總數</div><div class="icard-val" id="kpi-types" style="color:var(--amber)">—</div><div class="icard-sub" id="kpi-types-sub"></div></div>
    <div class="icard"><div class="icard-label">最標準化 RT</div><div class="icard-val" id="kpi-std" style="color:var(--blue);font-size:18px">—</div><div class="icard-sub" id="kpi-std-sub"></div></div>
    <div class="icard"><div class="icard-label">最分散 RT</div><div class="icard-val" id="kpi-div" style="color:var(--pink);font-size:18px">—</div><div class="icard-sub" id="kpi-div-sub"></div></div>
  </div>

  <div class="rt-grid" id="rtGrid"></div>

  <!-- L1/L2 Charts -->

  <div id="chartArea">
    <div class="chart-grid">
      <div class="card"><div class="card-title">Error Code 數量 vs SOP 種類數</div><canvas id="groupedBar" height="220"></canvas></div>
      <div class="card"><div class="card-title">分散程度比值（SOP種類 ÷ Error Code %）</div><canvas id="ratioBar" height="220"></canvas></div>
    </div>
    <div class="chart-grid-3">
      <div class="card"><div class="card-title">散佈圖</div><canvas id="scatter" height="240"></canvas><div class="legend-row" id="scatterLegend"></div></div>
      <div class="card"><div class="card-title">Error Code 佔比</div><canvas id="donut" height="240"></canvas></div>
      <div class="card"><div class="card-title">SOP 種類數排行</div><canvas id="hbar" height="240"></canvas></div>
    </div>
  </div>

  <!-- L3 SOP panel -->

  <div class="sop-panel" id="sopPanel" style="display:none;">
    <div class="sop-panel-header">
      <h2 id="sopTitle">—</h2>
      <div style="font-size:11px;color:var(--muted)" id="sopMeta"></div>
    </div>
    <input class="sop-search" id="sopSearch" placeholder="搜尋 SOP 內容 或 Error Code..." oninput="filterSOPs()">
    <div id="sopList"></div>
  </div>
</div>

