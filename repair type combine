Chart.defaults.color = '#64748b';
Chart.defaults.borderColor = '#2e3247';
Chart.defaults.font.family = "'Noto Sans TC', sans-serif";

const RT_ORDER = ['ENG','FAE','RT','FLH','CTL','MST','OP','RP1','DDR'];
const COLORS   = ['#6ee7b7','#f59e0b','#818cf8','#f472b6','#38bdf8','#fb923c','#a78bfa','#34d399','#fbbf24'];

let curProd = 'PCIe', curRT = null, charts = {}, allSOPs = [];

function selectProduct(p) {
  curProd = p; curRT = null;
  document.querySelectorAll('.lv1-tab').forEach(t => t.classList.toggle('active', t.dataset.p === p));
  document.getElementById('sopPanel').style.display = 'none';
  document.getElementById('chartArea').style.display = 'block';
  updateBreadcrumb();
  renderKPI();
  renderRTCards();
  renderCharts();
}

function selectRT(rt) {
  curRT = rt;
  document.querySelectorAll('.rt-card').forEach(c => c.classList.toggle('active', c.dataset.rt === rt));
  document.getElementById('sopPanel').style.display = 'block';
  document.getElementById('chartArea').style.display = 'none';
  updateBreadcrumb();
  renderSOPList(rt);
}

function backToCharts() {
  curRT = null;
  document.getElementById('sopPanel').style.display = 'none';
  document.getElementById('chartArea').style.display = 'block';
  document.querySelectorAll('.rt-card').forEach(c => c.classList.remove('active'));
  updateBreadcrumb();
}

function updateBreadcrumb() {
  const bc = document.getElementById('breadcrumb');
  let html = '';
  if (curRT) html += `<button class="back-btn" onclick="backToCharts()">← 返回</button> `;
  html += `<span class="${curRT ? '' : 'active'}" style="cursor:${curRT?'pointer':'default'}" onclick="${curRT?'backToCharts()':''}">${curProd}</span>`;
  if (curRT) html += `<span class="sep">›</span><span class="active">${curRT}</span>`;
  bc.innerHTML = html;
}

function renderKPI() {
  const pd = FULL_DATA[curProd];
  const rts = RT_ORDER.filter(rt => pd[rt]);
  const totals = rts.map(rt => pd[rt].total);
  const types  = rts.map(rt => pd[rt].types);
  const ratios = rts.map(rt => pd[rt].types / pd[rt].total * 100);
  const totalSum = totals.reduce((a,b)=>a+b,0);
  const typesSum = types.reduce((a,b)=>a+b,0);
  const minIdx = ratios.indexOf(Math.min(...ratios));
  const maxIdx = ratios.indexOf(Math.max(...ratios));
  document.getElementById('kpi-total').textContent = totalSum.toLocaleString();
  document.getElementById('kpi-total-sub').textContent = `共 ${rts.length} 種 Repair_Type`;
  document.getElementById('kpi-types').textContent = typesSum.toLocaleString();
  document.getElementById('kpi-types-sub').textContent = `平均每類 ${(typesSum/rts.length).toFixed(1)} 種`;
  document.getElementById('kpi-std').textContent = rts[minIdx];
  document.getElementById('kpi-std-sub').textContent = `比值 ${ratios[minIdx].toFixed(1)}% (${types[minIdx]}種/${totals[minIdx]}筆)`;
  document.getElementById('kpi-div').textContent = rts[maxIdx];
  document.getElementById('kpi-div-sub').textContent = `比值 ${ratios[maxIdx].toFixed(1)}% (${types[maxIdx]}種/${totals[maxIdx]}筆)`;
}

function renderRTCards() {
  const pd = FULL_DATA[curProd];
  document.getElementById('rtGrid').innerHTML = RT_ORDER.map((rt, i) => {
    const d = pd[rt];
    if (!d) return `<div class="rt-card" style="opacity:.3"><div class="rt-name" style="color:${COLORS[i]}">${rt}</div><div class="rt-total" style="font-size:14px;color:var(--muted)">—</div><div class="rt-sub">無資料</div></div>`;
    return `<div class="rt-card" data-rt="${rt}" onclick="selectRT('${rt}')">
      <div class="rt-name" style="color:${COLORS[i]}">${rt}</div>
      <div class="rt-total">${d.total}</div>
      <div class="rt-sub">${d.types} 種SOP · 點擊查看 →</div>
    </div>`;
  }).join('');
}

function renderSOPList(rt) {
  const d = FULL_DATA[curProd][rt];
  document.getElementById('sopTitle').textContent = `${curProd}  →  ${rt}`;
  document.getElementById('sopMeta').textContent = `共 ${d.total} 筆 Error Code · ${d.types} 種 SOP`;
  document.getElementById('sopSearch').value = '';
  allSOPs = d.sops;
  renderSOPItems(allSOPs);
}

function renderSOPItems(sops) {
  if (sops.length === 0) {
    document.getElementById('sopList').innerHTML = '<div class="empty-msg">沒有符合的結果</div>';
    return;
  }
  document.getElementById('sopList').innerHTML = sops.map((s, i) => `
    <div class="sop-item" id="sop-${i}">
      <div class="sop-header" onclick="toggleSOP(${i})">
        <span class="sop-badge">${s.codes.length} 筆</span>
        <span class="sop-text">${escHtml(s.sop)}</span>
        <span class="sop-arrow">▶</span>
      </div>
      <div class="sop-codes">
        <table class="code-table">
          <thead><tr><th>#</th><th>Error Code</th><th>ERR Stage</th><th>ERR Type</th></tr></thead>
          <tbody>${s.codes.map((c, j) => `<tr>
            <td style="color:var(--muted);font-family:JetBrains Mono,monospace;font-size:10px">${j+1}</td>
            <td><span class="code-tag">${escHtml(c.code)}</span></td>
            <td><span class="stage-tag">${escHtml(c.stage)}</span></td>
            <td><span class="type-tag">${escHtml(c.err_type)}</span></td>
          </tr>`).join('')}</tbody>
        </table>
      </div>
    </div>`).join('');
}

function toggleSOP(i) {
  document.getElementById(`sop-${i}`).classList.toggle('open');
}

function filterSOPs() {
  const q = document.getElementById('sopSearch').value.toLowerCase();
  if (!q) { renderSOPItems(allSOPs); return; }
  const filtered = allSOPs.filter(s =>
    s.sop.toLowerCase().includes(q) ||
    s.codes.some(c => c.code.toLowerCase().includes(q) || c.stage.toLowerCase().includes(q) || c.err_type.toLowerCase().includes(q))
  );
  renderSOPItems(filtered);
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function renderCharts() {
  const pd = FULL_DATA[curProd];
  const labels = RT_ORDER.filter(rt => pd[rt]);
  const totals = labels.map(rt => pd[rt].total);
  const types  = labels.map(rt => pd[rt].types);
  const ratios = labels.map(rt => +(pd[rt].types / pd[rt].total * 100).toFixed(1));
  const colors = labels.map((_, i) => COLORS[RT_ORDER.indexOf(labels[i])]);
  const pc = curProd === 'PCIe' ? '#6ee7b7' : '#f59e0b';
  const totalSum = totals.reduce((a,b)=>a+b,0);

  Object.values(charts).forEach(c => c && c.destroy());

  charts.grouped = new Chart(document.getElementById('groupedBar'), {
    type:'bar', data:{ labels, datasets:[
      {label:'Error Code 數量', data:totals, backgroundColor:pc+'cc', borderRadius:4, yAxisID:'y'},
      {label:'SOP種類數', data:types, backgroundColor:'#f472b6cc', borderRadius:4, yAxisID:'y2'}
    ]},
    options:{ plugins:{legend:{position:'bottom',labels:{padding:10,font:{size:11}}}},
      scales:{ x:{grid:{display:false}}, y:{position:'left',grid:{color:'rgba(46,50,71,.5)'},title:{display:true,text:'筆數',color:pc}}, y2:{position:'right',grid:{display:false},title:{display:true,text:'種類',color:'#f472b6'}} } }
  });

  charts.ratio = new Chart(document.getElementById('ratioBar'), {
    type:'bar', data:{labels, datasets:[{label:'種類/筆數(%)', data:ratios, backgroundColor:colors, borderRadius:4}]},
    options:{ indexAxis:'y', plugins:{legend:{display:false}, tooltip:{callbacks:{label:ctx=>` ${ctx.raw}%`}}},
      scales:{x:{grid:{color:'rgba(46,50,71,.5)'}}, y:{grid:{display:false}}} }
  });

  const scatterData = labels.map((k,i) => ({x:pd[k].total, y:pd[k].types, label:k, color:colors[i]}));
  charts.scatter = new Chart(document.getElementById('scatter'), {
    type:'scatter',
    data:{ datasets: scatterData.map(pt => ({label:pt.label, data:[{x:pt.x,y:pt.y}], backgroundColor:pt.color+'cc', borderColor:pt.color, pointRadius:8, pointHoverRadius:11})) },
    options:{ plugins:{legend:{display:false}, tooltip:{callbacks:{label:ctx=>` ${ctx.dataset.label}: ${ctx.parsed.x}筆 / ${ctx.parsed.y}種`}}},
      scales:{ x:{title:{display:true,text:'Error Code 數量',color:'#64748b'},grid:{color:'rgba(46,50,71,.5)'}}, y:{title:{display:true,text:'SOP種類數',color:'#64748b'},grid:{color:'rgba(46,50,71,.5)'}} } }
  });
  document.getElementById('scatterLegend').innerHTML = scatterData.map(pt =>
    `<div class="legend-item"><div class="legend-dot" style="background:${pt.color}"></div>${pt.label}</div>`).join('');

  charts.donut = new Chart(document.getElementById('donut'), {
    type:'doughnut',
    data:{labels, datasets:[{data:totals, backgroundColor:colors, borderColor:'#161b22', borderWidth:3, hoverOffset:6}]},
    options:{ cutout:'60%', plugins:{legend:{position:'bottom',labels:{padding:8,font:{size:10}}},
      tooltip:{callbacks:{label:ctx=>` ${ctx.label}: ${ctx.raw}筆 (${(ctx.raw/totalSum*100).toFixed(1)}%)`}}} }
  });

  const sorted = labels.map((k,i)=>({label:k,val:types[i],color:colors[i]})).sort((a,b)=>b.val-a.val);
  charts.hbar = new Chart(document.getElementById('hbar'), {
    type:'bar', data:{labels:sorted.map(s=>s.label), datasets:[{data:sorted.map(s=>s.val), backgroundColor:sorted.map(s=>s.color), borderRadius:4}]},
    options:{ indexAxis:'y', plugins:{legend:{display:false}}, scales:{x:{grid:{color:'rgba(46,50,71,.5)'}}, y:{grid:{display:false}}} }
  });
}

selectProduct('PCIe');
</script>

